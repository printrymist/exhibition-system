rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOperator() {
      return request.auth != null && request.auth.token.email == 'rymist1@gmail.com';
    }

    function isOrganizerEmail(emailField) {
      return request.auth != null
        && request.auth.token.email != null
        && emailField is string
        && emailField.lower() == request.auth.token.email.lower();
    }

    match /artworks/{docId} {
      // β-3 (2026-05-26): 公開 read を撤去。直 read は 3 経路に絞る。
      //   1. operator: 常時
      //   2. organizer: doc に denormalize した organizerEmail と一致する Firebase Auth
      //   3. visitor (gallery): role=visitor + exCode claim 一致 +
      //      _published=true + status='1' (空きスロットは隠す)
      //   それ以外 (anon QR / artist 招待 URL) は Cloud Function 経由
      //   (getArtwork / listArtworksByArtist / findEmptyArtworkSlot)。
      // 書き込みはすべて Cloud Function (submitArtwork / uploadArtworkImage 等) 経由。
      // security_key は使われなくなったが、互換性のために doc には残置。
      allow read: if
        isOperator()
        || (
          request.auth != null
          && request.auth.token.email != null
          && resource.data.organizerEmail is string
          && resource.data.organizerEmail.lower() == request.auth.token.email.lower()
        )
        || (
          request.auth != null
          && request.auth.token.role == 'visitor'
          && request.auth.token.exCode == resource.data.exCode
          && resource.data._published == true
          && resource.data.status == '1'
        );
      allow create, update: if false;
      allow delete: if isOperator();
    }

    // likes：読み取りを許可（ダッシュボード用）。
    // create:
    //   - 物理会場 QR (index.html anon) は引き続き無認証で受け入れる
    //   - gallery 経由は visitor custom token が必要 (claim の exCode と一致)
    //   - 運営者はテスト用に常時 OK
    // update / delete (Phase A-1, 2026-05-10):
    //   - visitor (Custom Token) で claim の sessionId と doc の sessionId が一致するときのみ許可
    //   - 自分が投稿したいいね・コメントを SNS と同じ感覚で取り消せるようにする目的
    //   - 物理 QR (anon) 経由は対象外 (Phase A-2 で別途検討)
    //   - 運営者はモデレーション目的で update/delete 可
    match /likes/{anyId} {
      allow read: if true;
      // anon (物理 QR) も create できる構造なので、各フィールドに型 + サイズ上限を課し、
      // さらに keys().hasOnly() で想定外フィールドの混入を禁止する (巨大 doc スパム / コスト対策)。
      // 列挙キーは index.html fsAddLike / gallery onLikeClick / onCommentSubmit が送る全フィールドの和集合。
      allow create: if
        request.resource.data.keys().hasOnly([
          'exCode', 'ex_name', 'workId', 'title', 'artist',
          'sessionId', 'nickname', 'comment', 'isLike', 'source', 'timestamp',
          'ownerKeyHash'
        ])
        && request.resource.data.exCode is string
        && request.resource.data.exCode.size() > 0
        && request.resource.data.exCode.size() < 50
        && request.resource.data.isLike is bool
        && request.resource.data.sessionId is string
        && request.resource.data.sessionId.size() < 200
        && (!('comment' in request.resource.data) || (request.resource.data.comment is string && request.resource.data.comment.size() < 2000))
        && (!('nickname' in request.resource.data) || (request.resource.data.nickname is string && request.resource.data.nickname.size() < 200))
        && (!('title' in request.resource.data) || (request.resource.data.title is string && request.resource.data.title.size() < 1000))
        && (!('artist' in request.resource.data) || (request.resource.data.artist is string && request.resource.data.artist.size() < 500))
        && (!('workId' in request.resource.data) || (request.resource.data.workId is string && request.resource.data.workId.size() < 200))
        && (!('ex_name' in request.resource.data) || (request.resource.data.ex_name is string && request.resource.data.ex_name.size() < 300))
        && (!('source' in request.resource.data) || (request.resource.data.source is string && request.resource.data.source.size() < 50))
        && (!('timestamp' in request.resource.data) || (request.resource.data.timestamp is string && request.resource.data.timestamp.size() < 100))
        && (!('ownerKeyHash' in request.resource.data) || (request.resource.data.ownerKeyHash is string && request.resource.data.ownerKeyHash.size() <= 64))
        && (
          request.auth == null
          || (
            request.auth.token.role == 'visitor'
            && request.auth.token.exCode == request.resource.data.exCode
          )
          || isOperator()
        );
      // #3 対策 (2026-06-13): visitor の直接 update/delete を撤去。
      // sessionId は公開 read で見えるうえ任意 sessionId の custom token を発行できたため、
      // sessionId 一致 gate は他人の like/comment 削除を許してしまっていた。
      // 取消/削除は CF deleteLike が ownerKey の指紋照合で本人確認してから admin SDK で行う。
      // operator はモデレーション目的で update/delete 可。
      allow update: if isOperator();
      allow delete: if isOperator();
    }

    match /exhibitions/{docId} {
      // 個別ドキュメントの取得は公開（来場者画面・作家画面で必要）
      allow get: if true;
      // 一覧クエリは「自分が主催者の展覧会のみ」または運営者管理者のみ
      allow list: if isOperator() || isOrganizerEmail(resource.data.email);
      // 新規作成は認証ユーザかつ自分のメアドを email フィールドに入れた場合のみ
      allow create: if isOperator() || isOrganizerEmail(request.resource.data.email);
      // 更新は運営者管理者または該当展覧会の主催者本人のみ
      allow update: if isOperator() || isOrganizerEmail(resource.data.email);
      allow delete: if isOperator() || isOrganizerEmail(resource.data.email);
    }

    // 問い合わせ：誰でも送信可。
    // 個別ドキュメント (get) は ID を知っていれば読める（リンク所持を実質的なアクセストークンとする）。
    // 一覧 (list) と更新は運営者（Google ログイン）のみ。

    match /inquiries/{inquiryId} {
      allow get: if true;
      allow list: if isOperator();
      allow create: if true;
      // 運営者は何でも更新可。
      // それ以外（リンク所持者）は status を 'open' に戻す変更だけ許可（続報送信時の通知用）。
      allow update: if isOperator() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'open'
      );
      allow delete: if isOperator();

      // 返信履歴サブコレクション
      // 読み取りは親 inquiry を読める者なら可（リンク所持者）。
      // 書き込みは運営者か、from='admin' で本文がある場合のみ（リンク所持者の続報）。
      //
      // NOTE: ここでの from='admin' は「問い合わせスレッドの author = リンク所持者本人」
      //   を指す legacy 命名で、運営者ではない。運営者の返信は inbox.html が
      //   from='operator' を書く (こちらは isOperator() 経由で通る)。
      //   non-operator が任意 inquiry に message create できるのは事実だが、
      //   inquiryId は Firestore auto-ID (20 文字ランダム) で unguessable なので
      //   実質的にメールリンク所持者しか到達できない。body は inbox.html /
      //   inquiry.html とも escapeHtml 経由で render され、stored XSS は成立しない。
      match /messages/{messageId} {
        allow read: if true;
        allow create: if isOperator() || (
          request.resource.data.from == 'admin'
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
        );
        allow update: if false;
        allow delete: if isOperator();
      }
    }

    // キャプションテンプレ（caption.html の保存済みテンプレ）
    // 2026-05-08 に「全員共有」から「ハイブリッド (運営者公式 + 各主催者 private)」に変更。
    //   運営者 (rymist1@gmail.com) のテンプレ = 公式ライブラリ、全員に表示
    //   各主催者 (organizer) のテンプレ = 本人だけに表示
    //   運営者は全部 read/write 可能 (admin)。
    // クライアント側 (caption.html loadSavedTemplates) は collection クエリの
    // 「全 doc が read OK」制約に対応するため where('createdBy', '==', ...) で
    // 自分用と公式の 2 クエリに分割している。
    match /caption_templates/{tplId} {
      allow read: if request.auth != null && (
        isOperator()
        || (
          resource.data.createdBy is string
          && (
            resource.data.createdBy.lower() == 'rymist1@gmail.com'
            || (request.auth.token.email != null
                && resource.data.createdBy.lower() == request.auth.token.email.lower())
          )
        )
      );
      allow create: if request.auth != null
        && request.auth.token.email != null
        && request.resource.data.createdBy is string
        && request.resource.data.createdBy.lower() == request.auth.token.email.lower();
      allow update, delete: if request.auth != null && (
        isOperator()
        || (
          resource.data.createdBy is string
          && request.auth.token.email != null
          && resource.data.createdBy.lower() == request.auth.token.email.lower()
        )
      );
    }

    // Phase E (2026-05-10): submitArtwork CF が変更履歴を append する監査ログ。
    // クライアントからの書き込みは禁止 (admin SDK 経由の CF だけが書ける)。
    // 読み取りは operator のみ (主催者の作品履歴閲覧 UI を後付けする場合は別の経路で渡す)。
    match /audit/{auditId} {
      allow read: if isOperator();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
