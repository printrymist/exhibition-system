rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 作品画像 / Web 展覧会の外観画像とも、書き込みは Cloud Function
    // (uploadArtworkImage / uploadGalleryImage) 経由のみ。
    // 直アップは filename を当てて誰でも上書き可になるため塞ぐ。
    match /artworks/{filename} {
      allow read: if true;
      allow write: if false;
    }

    match /gallery/{filename} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
